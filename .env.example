# =========================================================================
# FILE CẤU HÌNH BIẾN MÔI TRƯỜNG CHO PRODUCTION (DOCKER COMPOSE)
# Copy file này thành file `.env` cùng thư mục trên VPS và điền thông tin thực tế
# =========================================================================

# 1. Cơ sở dữ liệu (Supabase PostgreSQL Connection String)
# Chú ý: Cấu hình chung 1 Database 'postgres' của Supabase cho tất cả microservices
# EF Core sẽ tự động tạo các bảng riêng biệt mà không lo bị trùng lặp.
SUPABASE_DB_CONNECTION=Host=db.xxxxxxxxx.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_SUPABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;

# 2. Message Broker (CloudAMQP RabbitMQ)
# Hostname lấy từ trang CloudAMQP (không kèm amqps:// hay cổng)
CLOUDAMQP_HOST=xxxxx.rmq.cloudamqp.com
# Username và Password của instance được CloudAMQP cung cấp
CLOUDAMQP_USERNAME=your_cloudamqp_username
CLOUDAMQP_PASSWORD=your_cloudamqp_password
# VirtualHost của CloudAMQP mặc định giống hệt Username của bạn
CLOUDAMQP_VIRTUALHOST=your_cloudamqp_username

# 3. Bảo mật JWT
# Chuỗi bí mật dài ít nhất 32 ký tự dùng để mã hóa JWT Token
JWT_KEY=SuperSecretKeyForJwtAuthenticationThatIsLongEnoughToAvoidErrors123456!
