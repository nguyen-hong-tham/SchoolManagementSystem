@model CreateClassRequest
@{
    ViewData["Title"] = "Chỉnh Sửa Lớp Học";
    Layout = "_Layout";
    var classId = ViewBag.ClassId as Guid?;
}

<div class="mb-3">
    <a asp-action="Classes" class="btn btn-secondary" style="padding: 8px 16px; text-decoration: none;">← Quay lại danh sách lớp</a>
</div>

<div class="custom-card" style="max-width: 600px; margin: 0 auto;">
    <h3 style="margin-bottom: 20px; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px;">Chỉnh Sửa Lớp Học</h3>

    <form asp-action="EditClass" asp-route-id="@classId" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 15px; font-size: 0.9rem;"></div>

        <div class="form-group">
            <label asp-for="Name" class="form-label">Tên lớp học</label>
            <input asp-for="Name" class="form-control" placeholder="Ví dụ: 10A2, 11A1" required />
            <span asp-validation-for="Name" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="form-group">
            <label asp-for="GradeLevel" class="form-label">Khối lớp</label>
            <select asp-for="GradeLevel" class="form-control" required>
                <option value="10">Khối 10</option>
                <option value="11">Khối 11</option>
                <option value="12">Khối 12</option>
            </select>
            <span asp-validation-for="GradeLevel" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="form-group">
            <label asp-for="SchoolYear" class="form-label">Năm học</label>
            <input asp-for="SchoolYear" class="form-control" placeholder="Ví dụ: 2025-2026" required />
            <span asp-validation-for="SchoolYear" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div style="display: flex; gap: 12px; margin-top: 25px;">
            <button type="submit" class="btn btn-primary" style="flex: 1; padding: 12px;">Cập nhật</button>
            <a asp-action="Classes" class="btn btn-secondary" style="flex: 1; padding: 12px; text-align: center; text-decoration: none;">Hủy</a>
        </div>
    </form>
</div>
