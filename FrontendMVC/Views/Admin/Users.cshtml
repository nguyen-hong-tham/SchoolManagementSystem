<div class="custom-card">
    <!-- Action Row (Add Button & Global Search) -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;">
        <a asp-action="CreateUser" id="btn-add-user" class="btn btn-primary" style="padding: 10px 20px; text-decoration: none;">
            ➕ Thêm Người Dùng Mới
        </a>

        <div style="display: flex; gap: 10px; align-items: center;">
            <button id="btn-clear-filters" class="btn btn-secondary" style="padding: 8px 16px; white-space: nowrap;">Xóa bộ lọc</button>
        </div>
    </div>

    <!-- Tabs Container -->
    <div class="tabs-container">
        <button class="tab-btn active" data-tab="all">Tất cả</button>
        <button class="tab-btn" data-tab="teacher">Giáo viên</button>
        <button class="tab-btn" data-tab="student">Học sinh</button>
    </div>

    <!-- Responsive Table -->
    <div class="table-responsive">
        <table class="custom-table" id="users-table">
            <thead id="table-head">
                <!-- Populated dynamically via JS -->
            </thead>
            <tbody id="table-body">
                <!-- Populated dynamically via JS -->
            </tbody>
        </table>
    </div>
</div>

<!-- User Detail Modal Backdrop & Container -->
<div id="userDetailModal" class="modal-backdrop">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modalUserTitle">Chi tiết thông tin</h3>
            <button class="modal-close-btn" onclick="closeUserDetailModal()">&times;</button>
        </div>
        <div class="modal-body" id="modalUserBody">
            <!-- Dynamically populated -->
        </div>
    </div>
</div>

<!-- JavaScript Client-side Logic -->
<script>
    // 1. Raw Data from Backend
    const allUsers = @Html.Raw(Json.Serialize(Model)) || [];
    const allClasses = @Html.Raw(Json.Serialize(ViewBag.Classes)) || [];
    const allHomerooms = @Html.Raw(Json.Serialize(ViewBag.Homerooms)) || [];
    const allTeachingAssignments = @Html.Raw(Json.Serialize(ViewBag.TeachingAssignments)) || [];

    // Helper: Date formatter
    function formatDate(dateStr) {
        if (!dateStr) return '';
        const parts = dateStr.split('T')[0].split('-');
        if (parts.length !== 3) {
            const date = new Date(dateStr);
            if (isNaN(date.getTime())) return '';
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            return `${day}/${month}/${year}`;
        }
        return `${parts[2]}/${parts[1]}/${parts[0]}`;
    }

    // 2. Preprocess Data to include class & assignment details
    const processedUsers = allUsers.map(user => {
        const roleName = user.role === 0 ? 'Admin' : (user.role === 2 ? 'Teacher' : 'Student');
        const genderName = user.gender === 0 ? 'Nam' : 'Nữ';
        const dobFormatted = formatDate(user.dateOfBirth);
        
        let className = '';
        let teachingSubjects = [];
        let teachingClasses = [];
        let homeroomClassName = '';
        
        if (user.role === 1) { // Student
            const cls = allClasses.find(c => c.id === user.classId);
            className = cls ? cls.name : '';
        } else if (user.role === 2) { // Teacher
            // Homeroom Class
            const hr = allHomerooms.find(h => h.teacherId === user.id);
            if (hr) {
                const cls = allClasses.find(c => c.id === hr.classId);
                homeroomClassName = cls ? cls.name : (hr.className || '');
            }
            
            // Teaching Assignments
            const assignments = allTeachingAssignments.filter(ta => ta.teacherId === user.id);
            teachingSubjects = [...new Set(assignments.map(a => a.subjectName).filter(Boolean))];
            
            const classIds = [...new Set(assignments.map(a => a.classId).filter(Boolean))];
            teachingClasses = classIds.map(cid => {
                const cls = allClasses.find(c => c.id === cid);
                return cls ? cls.name : '';
            }).filter(Boolean);
        }
        
        return {
            ...user,
            roleName,
            genderName,
            dobFormatted,
            className,
            teachingSubjects,
            teachingClasses,
            homeroomClassName
        };
    });

    // 3. UI State Management
    const state = {
        activeTab: 'all',
        filters: {
            userCode: '',
            fullName: '',
            username: '',
            email: '',
            role: '',
            gender: '',
            className: '',
            subjectName: '',
            dateOfBirth: ''
        },
        sortColumn: 'userCode',
        sortDirection: 'asc'
    };

    // Deep link role filter compatibility
    const initialRole = '@roleFilter';
    if (initialRole === 'Admin') {
        state.activeTab = 'all';
        state.filters.role = 'Admin';
    } else if (initialRole === 'Teacher') {
        state.activeTab = 'teacher';
    } else if (initialRole === 'Student') {
        state.activeTab = 'student';
    }

    // 4. Action Row Forms Generator (using Anti-Forgery Token)
    function renderActions(user) {
        const editUrl = `/Admin/EditUser/${user.id}`;
        const deleteUrl = `/Admin/DeleteUser/${user.id}`;
        const tokenHtml = document.getElementById('antiforgery-token-container').innerHTML;
        
        return `
            <div style="display: flex; justify-content: flex-end; gap: 8px;">
                <button onclick="showUserDetail('${user.id}')" class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.85rem; border-color: #cbd5e1; background: #ffffff; color: #475569;">👁️ Xem</button>
                <a href="${editUrl}" class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.85rem; text-decoration: none; color: #4f46e5; border-color: #c7d2fe;"> Sửa</a>
                <form action="${deleteUrl}" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng ${user.fullName} (${user.userCode})?');">
                    ${tokenHtml}
                    <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 0.85rem;">Xóa</button>
                </form>
            </div>
        `;
    }

    // 5. Sorting Helper
    function sortData(data) {
        if (!state.sortColumn) return data;
        
        return [...data].sort((a, b) => {
            let valA = '';
            let valB = '';
            
            switch (state.sortColumn) {
                case 'userCode':
                    valA = a.userCode || '';
                    valB = b.userCode || '';
                    break;
                case 'fullName':
                    valA = a.fullName || '';
                    valB = b.fullName || '';
                    break;
                case 'dateOfBirth':
                    valA = a.dateOfBirth ? new Date(a.dateOfBirth).getTime() : 0;
                    valB = b.dateOfBirth ? new Date(b.dateOfBirth).getTime() : 0;
                    break;
                case 'className':
                    if (state.activeTab === 'student') {
                        valA = a.className || '';
                        valB = b.className || '';
                    } else if (state.activeTab === 'teacher') {
                        const classesA = [a.homeroomClassName, ...a.teachingClasses].filter(Boolean).sort().join(' | ');
                        const classesB = [b.homeroomClassName, ...b.teachingClasses].filter(Boolean).sort().join(' | ');
                        valA = classesA;
                        valB = classesB;
                    }
                    break;
                case 'subjectName':
                    valA = (a.teachingSubjects || []).sort().join(' | ');
                    valB = (b.teachingSubjects || []).sort().join(' | ');
                    break;
                default:
                    valA = a[state.sortColumn] || '';
                    valB = b[state.sortColumn] || '';
            }
            
            if (typeof valA === 'string') {
                return state.sortDirection === 'asc' 
                    ? valA.localeCompare(valB, 'vi', { sensitivity: 'base' })
                    : valB.localeCompare(valA, 'vi', { sensitivity: 'base' });
            } else {
                return state.sortDirection === 'asc' 
                    ? (valA > valB ? 1 : valA < valB ? -1 : 0)
                    : (valB > valA ? 1 : valB < valA ? -1 : 0);
            }
        });
    }

    // 6. Header and Filters Rendering
    function renderHeaders() {
        const head = document.getElementById('table-head');
        let html = '';
        let filterHtml = '';
        
        const getSortClass = (col) => {
            if (state.sortColumn !== col) return 'sortable';
            return `sortable ${state.sortDirection}`;
        };
        
        if (state.activeTab === 'all') {
            html = `
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th class="${getSortClass('userCode')}" data-col="userCode">Mã số</th>
                    <th class="${getSortClass('fullName')}" data-col="fullName">Họ và Tên</th>
                    <th class="${getSortClass('username')}" data-col="username">Tên tài khoản</th>
                    <th class="${getSortClass('email')}" data-col="email">Email</th>
                    <th>Vai trò</th>
                    <th>Giới tính</th>
                    <th class="${getSortClass('dateOfBirth')}" data-col="dateOfBirth">Ngày sinh</th>
                    <th style="text-align: right; width: 180px;">Hành Động</th>
                </tr>
            `;
            
            filterHtml = `
                <tr class="filter-row">
                    <td></td>
                    <td><input type="text" class="filter-input" data-filter="userCode" placeholder="Mã..." value="${state.filters.userCode}" /></td>
                    <td><input type="text" class="filter-input" data-filter="fullName" placeholder="Tên..." value="${state.filters.fullName}" /></td>
                    <td><input type="text" class="filter-input" data-filter="username" placeholder="Username..." value="${state.filters.username}" /></td>
                    <td><input type="text" class="filter-input" data-filter="email" placeholder="Email..." value="${state.filters.email}" /></td>
                    <td>
                        <select class="filter-select" data-filter="role">
                            <option value="">Tất cả</option>
                            <option value="Admin" ${state.filters.role === 'Admin' ? 'selected' : ''}>Admin</option>
                            <option value="Teacher" ${state.filters.role === 'Teacher' ? 'selected' : ''}>Giáo viên</option>
                            <option value="Student" ${state.filters.role === 'Student' ? 'selected' : ''}>Học sinh</option>
                        </select>
                    </td>
                    <td>
                        <select class="filter-select" data-filter="gender">
                            <option value="">Tất cả</option>
                            <option value="Nam" ${state.filters.gender === 'Nam' ? 'selected' : ''}>Nam</option>
                            <option value="Nữ" ${state.filters.gender === 'Nữ' ? 'selected' : ''}>Nữ</option>
                        </select>
                    </td>
                    <td><input type="text" class="filter-input" data-filter="dateOfBirth" placeholder="Ngày/năm..." value="${state.filters.dateOfBirth}" /></td>
                    <td></td>
                </tr>
            `;
        } else if (state.activeTab === 'teacher') {
            // Build unique class and subject list
            const uniqueClasses = [...new Set(allClasses.map(c => c.name).filter(Boolean))].sort();
            const classOptions = uniqueClasses.map(c => `<option value="${c}" ${state.filters.className === c ? 'selected' : ''}>${c}</option>`).join('');
            
            const uniqueSubjects = [...new Set(allTeachingAssignments.map(a => a.subjectName).filter(Boolean))].sort();
            const subjectOptions = uniqueSubjects.map(s => `<option value="${s}" ${state.filters.subjectName === s ? 'selected' : ''}>${s}</option>`).join('');

            html = `
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th class="${getSortClass('userCode')}" data-col="userCode">Mã giáo viên</th>
                    <th class="${getSortClass('fullName')}" data-col="fullName">Họ và Tên</th>
                    <th class="${getSortClass('subjectName')}" data-col="subjectName">Môn giảng dạy</th>
                    <th class="${getSortClass('className')}" data-col="className">Lớp phụ trách</th>
                    <th class="${getSortClass('email')}" data-col="email">Email</th>
                    <th>Giới tính</th>
                    <th class="${getSortClass('dateOfBirth')}" data-col="dateOfBirth">Ngày sinh</th>
                    <th style="text-align: right; width: 180px;">Hành Động</th>
                </tr>
            `;
            
            filterHtml = `
                <tr class="filter-row">
                    <td></td>
                    <td><input type="text" class="filter-input" data-filter="userCode" placeholder="Mã..." value="${state.filters.userCode}" /></td>
                    <td><input type="text" class="filter-input" data-filter="fullName" placeholder="Tên..." value="${state.filters.fullName}" /></td>
                    <td>
                        <select class="filter-select" data-filter="subjectName">
                            <option value="">Tất cả môn</option>
                            ${subjectOptions}
                        </select>
                    </td>
                    <td>
                        <input type="text" class="filter-input" data-filter="className" placeholder="Lớp..." value="${state.filters.className}" />
                    </td>
                    <td><input type="text" class="filter-input" data-filter="email" placeholder="Email..." value="${state.filters.email}" /></td>
                    <td>
                        <select class="filter-select" data-filter="gender">
                            <option value="">Tất cả</option>
                            <option value="Nam" ${state.filters.gender === 'Nam' ? 'selected' : ''}>Nam</option>
                            <option value="Nữ" ${state.filters.gender === 'Nữ' ? 'selected' : ''}>Nữ</option>
                        </select>
                    </td>
                    <td><input type="text" class="filter-input" data-filter="dateOfBirth" placeholder="Ngày/năm..." value="${state.filters.dateOfBirth}" /></td>
                    <td></td>
                </tr>
            `;
        } else if (state.activeTab === 'student') {
            const uniqueClasses = [...new Set(allClasses.map(c => c.name).filter(Boolean))].sort();
            const classOptions = uniqueClasses.map(c => `<option value="${c}" ${state.filters.className === c ? 'selected' : ''}>${c}</option>`).join('');

            html = `
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th class="${getSortClass('userCode')}" data-col="userCode">Mã học sinh</th>
