                            <div class="info-item" style="grid-column: span 2; margin-top: 10px;">
                                <span class="info-label">Lớp chủ nhiệm</span>
                                <span class="info-value">${data.homeroomClassName ? 'Lớp ' + data.homeroomClassName : 'Không có'}</span>
                            </div>
                        </div>
                    `;
                } else if (u.role === 0) {
                    // Admin detail template
                    modalTitle.innerText = `Chi tiết Quản trị viên: ${u.fullName}`;
                    const createdAt = u.createdAt ? new Date(u.createdAt).toLocaleDateString('vi-VN') : '—';
                    
                    modalBody.innerHTML = `
                        <div class="modal-section-title" style="margin-top: 0; grid-column: span 2;">Thông Tin Cá Nhân</div>
                        <div class="info-grid" style="grid-column: span 2;">
                            <div class="info-item">
                                <span class="info-label">Mã số</span>
                                <span class="info-value">${u.userCode}</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Họ và tên</span>
                                <span class="info-value">${u.fullName}</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Giới tính</span>
                                <span class="info-value">${genderStr}</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Ngày sinh</span>
                                <span class="info-value">${dob}</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Email</span>
                                <span class="info-value">${u.email || '—'}</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Số điện thoại</span>
                                <span class="info-value">${u.phoneNumber || '—'}</span>
                            </div>
                            <div class="info-item" style="grid-column: span 2;">
                                <span class="info-label">Địa chỉ</span>
                                <span class="info-value">${u.address || '—'}</span>
                            </div>
                        </div>
                        
                        <div class="modal-section-title" style="grid-column: span 2;">Thông Tin Hệ Thống</div>
                        <div class="info-grid" style="grid-column: span 2;">
                            <div class="info-item">
                                <span class="info-label">Vai trò</span>
                                <span class="info-value">Quản trị viên (Admin)</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Ngày tạo tài khoản</span>
                                <span class="info-value">${createdAt}</span>
                            </div>
                        </div>
                    `;
                }
            })
            .catch(err => {
                modalBody.innerHTML = `<div class="alert alert-danger" style="grid-column: span 2; margin: 0;">Lỗi kết nối máy chủ khi lấy chi tiết thông tin.</div>`;
            });
    }

    function updateAddUserButton() {
        const btn = document.getElementById('btn-add-user');
        if (!btn) return;
        if (state.activeTab === 'teacher') {
            btn.href = '/Admin/CreateUser?role=Teacher';
        } else if (state.activeTab === 'student') {
            btn.href = '/Admin/CreateUser?role=Student';
        } else {
            btn.href = '/Admin/CreateUser';
        }
    }

    // 9. Event Listeners Wiring
    document.addEventListener('DOMContentLoaded', () => {
        // Close modal when clicking outside content
        window.addEventListener('click', (event) => {
            const modal = document.getElementById('userDetailModal');
            if (event.target === modal) {
                closeUserDetailModal();
            }
        });

        // Wire tabs switching
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                e.target.classList.add('active');
                state.activeTab = e.target.dataset.tab;
                
                // Clear column filters upon tab change
                for (let key in state.filters) {
                    state.filters[key] = '';
                }
                
                updateAddUserButton();
                renderHeaders();
                updateTable();
            });
        });

        // Wire Clear Filter button
        document.getElementById('btn-clear-filters').addEventListener('click', () => {
            for (let key in state.filters) {
                state.filters[key] = '';
            }
            renderHeaders();
            updateTable();
        });

        // Set initial active tab state based on initial role compatibility
        if (state.activeTab !== 'all') {
            document.querySelectorAll('.tab-btn').forEach(b => {
                if (b.dataset.tab === state.activeTab) {
                    b.classList.add('active');
                } else {
                    b.classList.remove('active');
                }
            });
        }

        updateAddUserButton();
        // Initialize table
        renderHeaders();
        updateTable();
    });
</script>
