        modal.offsetHeight;
        modal.classList.add('show');
        
        // Display spinner
        modalBody.innerHTML = `
            <div class="spinner-container" style="grid-column: span 2;">
                <div class="spinner"></div>
                <div style="font-weight: 500;">Đang tải thông tin...</div>
            </div>
        `;
        
        // Fetch user json
        fetch(`/Admin/GetUserJson/${userId}`)
            .then(res => res.json())
