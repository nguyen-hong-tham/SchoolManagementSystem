@model IEnumerable<UserViewModel>
@{
    ViewData["Title"] = "";
    Layout = "_Layout";
    var searchValue = ViewBag.Search as string;
    var roleFilter = ViewBag.RoleFilter as string;
}

<!-- CSS Style Block for Modern Design -->
<style>
    /* Stats Dashboard */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 25px;
    }

    .stats-card {
        background: #ffffff;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid #e2e8f0;
    }

    .stats-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.03);
    }

    .stats-card.card-total { border-left: 5px solid #3b82f6; }
    .stats-card.card-teacher { border-left: 5px solid #6366f1; }
    .stats-card.card-student { border-left: 5px solid #10b981; }
    .stats-card.card-admin { border-left: 5px solid #f59e0b; }

    .stats-info h4 {
        margin: 0;
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .stats-info .value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1e293b;
        margin-top: 5px;
    }

    .stats-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .card-total .stats-icon { background: #eff6ff; color: #3b82f6; }
    .card-teacher .stats-icon { background: #e0e7ff; color: #6366f1; }
    .card-student .stats-icon { background: #ecfdf5; color: #10b981; }
    .card-admin .stats-icon { background: #fffbeb; color: #f59e0b; }

    /* Tabs */
    .tabs-container {
        display: flex;
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 25px;
        gap: 10px;
    }

    .tab-btn {
        padding: 12px 24px;
        font-size: 0.95rem;
        font-weight: 600;
        color: #64748b;
        background: transparent;
        border: none;
        border-bottom: 3px solid transparent;
        cursor: pointer;
        transition: all 0.2s;
        outline: none;
    }

    .tab-btn:hover {
        color: #4f46e5;
    }

    .tab-btn.active {
        color: #4f46e5;
        border-bottom-color: #4f46e5;
    }

    /* Table sortable headers */
    .sortable {
        cursor: pointer;
        user-select: none;
        position: relative;
        padding-right: 20px !important;
    }

    .sortable::after {
        content: " ↕";
        position: absolute;
        right: 8px;
        opacity: 0.3;
        font-size: 0.75rem;
    }

    .sortable.asc::after {
        content: " ▲";
        opacity: 1;
        color: #4f46e5;
    }

    .sortable.desc::after {
        content: " ▼";
        opacity: 1;
        color: #4f46e5;
    }

    /* Filter controls in table */
    .filter-row td {
        padding: 8px 10px !important;
        background-color: #f8fafc;
        border-top: none !important;
    }

    .filter-input {
        width: 100%;
        padding: 6px 10px;
        font-size: 0.85rem;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        background-color: #ffffff;
    }

    .filter-input:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .filter-select {
        width: 100%;
        padding: 6px 10px;
        font-size: 0.85rem;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        outline: none;
        background-color: #ffffff;
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .filter-select:focus {
        border-color: #6366f1;
    }

    /* Badges for classes and subjects */
    .class-badge {
        background-color: #e0e7ff;
        color: #4338ca;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        margin: 2px;
        border: 1px solid #c7d2fe;
    }

    .class-badge.homeroom {
        background-color: #fef3c7;
        color: #b45309;
        border: 1px dashed #f59e0b;
    }

    .subject-badge {
        background-color: #f1f5f9;
        color: #334155;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        margin: 2px;
        border: 1px solid #e2e8f0;
    }

    /* Modern Modal Styling matching ClassDetail.cshtml */
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(15, 23, 42, 0.65);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        opacity: 0;
        transition: opacity 0.25s ease-in-out;
    }
    .modal-backdrop.show {
        opacity: 1;
    }
    .modal-content {
        background-color: #ffffff;
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
        width: 90%;
        max-width: 680px;
        max-height: 85vh;
        overflow-y: auto;
        border: 1px solid var(--border-color);
        transform: scale(0.95);
        transition: transform 0.25s ease-in-out;
    }
    .modal-backdrop.show .modal-content {
        transform: scale(1);
    }
    .modal-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #f8fafc;
        border-top-left-radius: 16px;
        border-top-right-radius: 16px;
    }
    .modal-header h3 {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--color-text-dark);
    }
    .modal-close-btn {
        background: none;
        border: none;
        font-size: 1.75rem;
        font-weight: 500;
        color: var(--color-text-light);
        cursor: pointer;
        transition: color 0.15s ease;
        line-height: 1;
    }
    .modal-close-btn:hover {
        color: var(--color-danger);
    }
    .modal-body {
        padding: 24px;
    }
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .info-item {
        display: flex;
        flex-direction: column;
    }
    .info-label {
        font-size: 0.85rem;
        color: var(--color-text-light);
        margin-bottom: 4px;
        font-weight: 500;
    }
    .info-value {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text-dark);
    }
    .modal-section-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--color-primary);
        border-bottom: 2px solid var(--color-primary);
        padding-bottom: 6px;
        margin-bottom: 16px;
        margin-top: 24px;
    }
    .spinner-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
        color: var(--color-text-light);
        gap: 12px;
    }
    .spinner {
        border: 4px solid rgba(79, 70, 229, 0.1);
        border-top: 4px solid var(--color-primary);
        border-radius: 50%;
        width: 45px;
        height: 45px;
        animation: spin 1s linear infinite;
    }
    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    .gpa-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 1.15rem;
        margin-bottom: 15px;
        border: 1px solid transparent;
    }
    .gpa-badge.success {
        background-color: #ecfdf5;
        color: var(--color-success);
        border-color: #a7f3d0;
    }
    .gpa-badge.warning {
        background-color: #fffbeb;
        color: var(--color-warning);
        border-color: #fde68a;
    }
    .gpa-badge.danger {
        background-color: #fef2f2;
        color: var(--color-danger);
        border-color: #fca5a5;
    }
    .modal-tab-btn.active {
        color: var(--color-primary) !important;
        border-bottom-color: var(--color-primary) !important;
    }
    .modal-tab-btn:hover {
        color: var(--color-primary) !important;
    }
</style>

<!-- Hidden anti-forgery token container -->
<div id="antiforgery-token-container" style="display: none;">
    @Html.AntiForgeryToken()
</div>

