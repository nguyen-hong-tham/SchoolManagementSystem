                            <option value="">Tất cả</option>
                            <option value="Nam" ${state.filters.gender === 'Nam' ? 'selected' : ''}>Nam</option>
                            <option value="Nữ" ${state.filters.gender === 'Nữ' ? 'selected' : ''}>Nữ</option>
                        </select>
                    </td>
                    <td><input type="text" class="filter-input" data-filter="dateOfBirth" placeholder="Ngày/năm..." value="${state.filters.dateOfBirth}" /></td>
                    <td></td>
                </tr>
            `;
        }
        
        head.innerHTML = html + filterHtml;
        
        // Wire sort headers
        head.querySelectorAll('.sortable').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.col;
                if (state.sortColumn === col) {
                    state.sortDirection = state.sortDirection === 'asc' ? 'desc' : 'asc';
                } else {
                    state.sortColumn = col;
                    state.sortDirection = 'asc';
                }
                updateTable();
            });
        });
        
        // Wire text inputs
        head.querySelectorAll('.filter-input').forEach(input => {
            input.addEventListener('input', (e) => {
                const field = e.target.dataset.filter;
                state.filters[field] = e.target.value;
                updateTable();
            });
        });
        
        // Wire dropdown selectors
        head.querySelectorAll('.filter-select').forEach(select => {
            select.addEventListener('change', (e) => {
                const field = e.target.dataset.filter;
                state.filters[field] = e.target.value;
                updateTable();
            });
        });
    }

    // 7. Filter & Render Data
    function updateTable() {
        // Filter users dynamically (ignoring role check for statistics computation)
        const statsFiltered = processedUsers.filter(user => {
            // Column filters matching
            if (state.filters.userCode && !user.userCode.toLowerCase().includes(state.filters.userCode.toLowerCase())) return false;
            if (state.filters.fullName && !user.fullName.toLowerCase().includes(state.filters.fullName.toLowerCase())) return false;
            if (state.filters.username && user.username && !user.username.toLowerCase().includes(state.filters.username.toLowerCase())) return false;
            if (state.filters.email && user.email && !user.email.toLowerCase().includes(state.filters.email.toLowerCase())) return false;
            
            if (state.filters.gender && user.genderName !== state.filters.gender) return false;
            if (state.filters.dateOfBirth && !user.dobFormatted.includes(state.filters.dateOfBirth)) return false;

            // Conditional filters matching
            if (state.filters.role && user.roleName !== state.filters.role) return false;
            
            if (state.filters.className) {
                const filterLower = state.filters.className.toLowerCase();
                if (user.role === 1) { // Student
                    if (!user.className || !user.className.toLowerCase().includes(filterLower)) return false;
                } else if (user.role === 2) { // Teacher
                    const matchesHomeroom = user.homeroomClassName && user.homeroomClassName.toLowerCase().includes(filterLower);
                    const matchesTeaching = user.teachingClasses && user.teachingClasses.some(c => c.toLowerCase().includes(filterLower));
                    if (!matchesHomeroom && !matchesTeaching) return false;
                } else {
                    return false; // Admins don't belong to any class
                }
            }

            if (state.filters.subjectName) {
                if (user.role === 2) { // Teacher
                    if (!user.teachingSubjects.includes(state.filters.subjectName)) return false;
                } else {
                    return false; // Admins / Students don't teach
                }
            }

            return true;
        });

        // Compute and update statistics
        //document.getElementById('stat-total-users').innerText = statsFiltered.length;
        //document.getElementById('stat-total-teachers').innerText = statsFiltered.filter(u => u.role === 2).length;
       // document.getElementById('stat-total-students').innerText = statsFiltered.filter(u => u.role === 1).length;
        //document.getElementById('stat-total-admins').innerText = statsFiltered.filter(u => u.role === 0).length;

        // Apply tab filter
        let tabFiltered = statsFiltered;
        if (state.activeTab === 'teacher') {
            tabFiltered = statsFiltered.filter(u => u.role === 2);
        } else if (state.activeTab === 'student') {
            tabFiltered = statsFiltered.filter(u => u.role === 1);
        }

        // Apply sort
        const sorted = sortData(tabFiltered);

        // Render Table Body
        const body = document.getElementById('table-body');
        if (sorted.length === 0) {
            let colspan = state.activeTab === 'all' ? 9 : (state.activeTab === 'teacher' ? 9 : 8);
            body.innerHTML = `
                <tr>
                    <td colspan="${colspan}" class="text-center text-muted" style="padding: 30px 0;">Không tìm thấy người dùng nào.</td>
                </tr>
            `;
            return;
        }

        let html = '';
        sorted.forEach((user, index) => {
            if (state.activeTab === 'all') {
                let roleBadge = '';
                if (user.role === 0) {
                    roleBadge = '<span class="badge" style="background-color: #fef3c7; color: #d97706;">Admin</span>';
                } else if (user.role === 2) {
                    roleBadge = '<span class="badge" style="background-color: #e0e7ff; color: #4f46e5;">Giáo viên</span>';
                } else {
                    roleBadge = '<span class="badge" style="background-color: #d1fae5; color: #059669;">Học sinh</span>';
                }

                html += `
                    <tr>
                        <td>${index + 1}</td>
                        <td class="fw-bold">${user.userCode}</td>
                        <td class="fw-bold" style="color: #1e293b;"><a href="javascript:void(0);" onclick="showUserDetail('${user.id}')" style="color: #4f46e5; text-decoration: none; border-bottom: 1px dashed #c7d2fe;">${user.fullName}</a></td>
                        <td>${user.username || ''}</td>
                        <td>${user.email || ''}</td>
                        <td>${roleBadge}</td>
                        <td>${user.genderName}</td>
                        <td>${user.dobFormatted}</td>
                        <td>${renderActions(user)}</td>
                    </tr>
                `;
            } else if (state.activeTab === 'teacher') {
                // Formatting teaching subjects as badges
                const subjectsHtml = user.teachingSubjects.length > 0 
                    ? user.teachingSubjects.map(s => `<span class="subject-badge">${s}</span>`).join('')
                    : '<span class="text-muted" style="font-style: italic; font-size: 0.85rem;">Chưa phân công</span>';
                
                // Formatting classes as badges
                let classesHtml = '';
                if (user.homeroomClassName) {
                    classesHtml += `<span class="class-badge homeroom" title="Lớp chủ nhiệm">⭐ ${user.homeroomClassName} (CN)</span>`;
                }
                const otherClasses = user.teachingClasses.filter(c => c !== user.homeroomClassName);
                if (otherClasses.length > 0) {
                    classesHtml += otherClasses.map(c => `<span class="class-badge">${c}</span>`).join('');
                }
                if (!classesHtml) {
                    classesHtml = '<span class="text-muted" style="font-style: italic; font-size: 0.85rem;">Chưa phân công lớp</span>';
                }

                html += `
                    <tr>
                        <td>${index + 1}</td>
                        <td class="fw-bold">${user.userCode}</td>
                        <td class="fw-bold" style="color: #1e293b;"><a href="javascript:void(0);" onclick="showUserDetail('${user.id}')" style="color: #4f46e5; text-decoration: none; border-bottom: 1px dashed #c7d2fe;">${user.fullName}</a></td>
                        <td>${subjectsHtml}</td>
                        <td>${classesHtml}</td>
                        <td>${user.email || ''}</td>
                        <td>${user.genderName}</td>
                        <td>${user.dobFormatted}</td>
                        <td>${renderActions(user)}</td>
                    </tr>
                `;
            } else if (state.activeTab === 'student') {
                const classHtml = user.className 
                    ? `<span class="class-badge" style="background-color: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0;">${user.className}</span>`
                    : '<span class="text-muted" style="font-style: italic; font-size: 0.85rem;">Chưa xếp lớp</span>';

                html += `
                    <tr>
                        <td>${index + 1}</td>
                        <td class="fw-bold">${user.userCode}</td>
                        <td class="fw-bold" style="color: #1e293b;"><a href="javascript:void(0);" onclick="showUserDetail('${user.id}')" style="color: #4f46e5; text-decoration: none; border-bottom: 1px dashed #c7d2fe;">${user.fullName}</a></td>
                        <td>${classHtml}</td>
                        <td>${user.email || ''}</td>
                        <td>${user.genderName}</td>
                        <td>${user.dobFormatted}</td>
                        <td>${renderActions(user)}</td>
                    </tr>
                `;
            }
        });

        body.innerHTML = html;
    }

    // Helper: Group student scores
    function groupStudentScores(scores) {
        const grouped = {};
        scores.forEach(s => {
            const subCode = s.subjectCode;
            if (!grouped[subCode]) {
                grouped[subCode] = {
                    subjectName: s.subjectName,
                    subjectCode: s.subjectCode,
                    oral: '—',
                    midterm: '—',
                    final: '—'
                };
            }
            
            const type = s.type.toLowerCase();
            if (type === 'oral') grouped[subCode].oral = s.scoreValue;
            else if (type === 'midterm') grouped[subCode].midterm = s.scoreValue;
            else if (type === 'final') grouped[subCode].final = s.scoreValue;
        });
        return Object.values(grouped);
    }

    window.switchModalTab = function(event, tabId) {
        document.querySelectorAll('.modal-tab-content').forEach(el => {
            el.style.display = 'none';
        });
        document.querySelectorAll('.modal-tab-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        const activeTabPanel = document.getElementById(tabId);
        if (activeTabPanel) {
            activeTabPanel.style.display = 'block';
        }
        if (event) {
            event.currentTarget.classList.add('active');
        }
    };

    // Modal control functions
    window.closeUserDetailModal = function() {
        const modal = document.getElementById('userDetailModal');
        if (!modal) return;
        modal.classList.remove('show');
        setTimeout(() => {
            modal.style.display = 'none';
        }, 250);
    };

    // 8. User Detail Modal Logic
